# Google Places API Key
# Go to Google Cloud Console, enable Places API (New) and create an API Key.
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Serper.dev Google Search API Key (Recommended Option A)
# Register at serper.dev to get a key with 2500 free search queries.
SERPER_API_KEY=your_serper_api_key_here

# Google Custom Search JSON API Key & Search Engine ID
# Go to Programmable Search Engine (cse.google.com), create a search engine configured to search the entire web.
# Go to Google Cloud Console, enable Custom Search API and create an API Key.
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_google_search_engine_id_here

# Server Configuration
PORT=3000

# GitHub Templates Repository Configurations
GITHUB_USERNAME=your_github_username
GITHUB_REPO=your_templates_repo_name
GITHUB_BRANCH=main
GITHUB_TOKEN=your_github_token_here

# Discord Webhook Notifications Configuration
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
DISCORD_USER_ID=

# Agency CTAs
AGENCY_FIVERR_URL=https://www.fiverr.com/s/gDeZRvL
AGENCY_WHATSAPP_PHONE=919999999999
